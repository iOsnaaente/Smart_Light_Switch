POSTGRES_USER=postgres_user
POSTGRES_PASSWORD=postgres_password
POSTGRES_DB=postgres_db
POSTGRES_HOST=postgres_host
POSTGRES_PORT=postgres_port

AUTH_USERNAME=user_admin
AUTH_PASSWORD=senha_admin

MQTT_HOST=mosquitto
MQTT_PORT=1883

# Opcionais — preencha se o broker exigir autenticação (allow_anonymous false
# + password_file no mosquitto.conf, criado com `mosquitto_passwd`). Deixe em
# branco se o broker aceitar conexões anônimas.
MQTT_USERNAME=backend
MQTT_PASSWORD=backend_password
